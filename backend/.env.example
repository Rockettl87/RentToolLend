# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/renttoolend

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d

# Stripe (Platform owner: Brad)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Brad's Stripe account ID (where 20% platform fee goes)
STRIPE_PLATFORM_ACCOUNT_ID=acct_your_platform_account_id

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@renttoolend.com

# Frontend URL
CLIENT_URL=http://localhost:3000

# Platform Fee (20%)
PLATFORM_FEE_PERCENT=20

# Insurance Fee (10% of rental total added to each booking)
INSURANCE_FEE_PERCENT=10

# Admin
ADMIN_EMAIL=brad@renttoolend.com
